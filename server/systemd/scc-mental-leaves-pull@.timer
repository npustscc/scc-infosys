# scc-mental-leaves-pull@.timer — 每 10 分鐘觸發一次 scc-mental-leaves-pull@.service。
#
# 安裝方式與參數說明見同目錄 README.md。

[Unit]
Description=每 10 分鐘拉取一次身心調適假信箱解析結果（%i）

[Timer]
OnCalendar=*:0/10
# 隨機延遲：避免 dev/prod 等多實例、或系統重開機後大量 timer 同時觸發時集中打 Google API。
RandomizedDelaySec=60
# 錯過的執行（例如機器重開機、timer 服務暫停期間）於下次啟動後補跑一次，
# 避免長時間斷線後累積過多封待解析信件。
Persistent=true

[Install]
WantedBy=timers.target
