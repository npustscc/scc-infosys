# server/.env — 機密設定，絕不可 commit（server/.env 已列入根目錄 .gitignore）。
# 部署前複製本檔為 server/.env 並填入實際值。

# HMAC session token 簽章密鑰；務必為高熵隨機字串（建議：openssl rand -hex 32）。
# 缺少此值時 config.js 會 fail-fast（拒絕啟動），避免用預設/空密鑰簽發可偽造的 session。
SESSION_SECRET=

# 監聽埠
PORT=8787

# SQLite 資料庫檔路徑（相對於 server/ 或絕對路徑）；server/data/ 已列入 .gitignore。
DB_PATH=./data/dev.sqlite

# 虛擬 Drive 的根資料夾 ID（沿用 GAS 版 dev 環境值，作為 vdrive 命名空間鍵與前端相容性錨點）。
# 正式部署（VM/實體機）時應改用專屬值；本機開發可沿用 dev 版 ID。
ROOT_FOLDER_ID=1rZuVUhpHwrSYc2E0yJRvf7NaqS1lGcdx

# Phase 2 GAS 瘦身橋接：日曆同步等 action 尚未在 Node 實作，設定此值後會轉發到既有 GAS 後端；
# 留空則一律回傳「Not implemented (phase 2 GAS proxy)」業務錯誤。
# （npust5 信件解析 4 個 action 已改走本機 Gmail REST 直連，見下方 GMAIL_SYNC_CREDS，不再走此代理。）
GAS_PROXY_URL=

# 打卡紀錄 Drive 拉取器（scripts/pull-attendance.js）與 v200 附件 Drive 舊資料唯讀 fallback
# （src/actions/attachments.js downloadFileBase64 Tier 3，見下方 DRIVE_LEGACY_ROOTS）共用：
# 指向唯讀 OAuth 憑證 JSON 檔路徑（{client_id, client_secret, refresh_token}，refresh_token 的
# scope 需含 https://www.googleapis.com/auth/drive.readonly）。留空則打卡拉取器 fail-fast、
# 附件 Drive fallback 不啟用（該 fallback 另需搭配 DRIVE_LEGACY_ROOTS，兩者皆設才生效）。
DRIVE_SYNC_CREDS=

# 身心調適假信箱解析（scripts/pull-mental-leaves.js＋dispatch fetchMentalLeaves/clearMentalLeaves
# action）專用：指向唯讀以外還需寫入權限的 OAuth 憑證 JSON 檔路徑（{client_id, client_secret,
# refresh_token}，refresh_token 的 scope 需含 https://www.googleapis.com/auth/gmail.modify）。
# 留空則 fetchMentalLeaves/clearMentalLeaves 回業務錯誤，CLI 直接 fail-fast。
GMAIL_SYNC_CREDS=

# Gmail 已處理信件 label 名稱：對映 GAS 版 dev=ml-processed-dev／prod=ml-processed（依部署環境
# 分別在各自 .env 設定，不可共用同一個 npust5 信箱＋同一個 label，否則 dev/prod 會互相汙染彼此
# 的已處理狀態）。
ML_GMAIL_LABEL=ml-processed-dev

# 個案物件級授權（R1）模式：shadow=只記 audit、原樣回傳；enforce=實際依可見性剝除臨床內容。
# Phase 1 骨架固定 shadow，此處保留供未來切換。
CASE_AUTHZ_MODE=shadow

# issues.json dev/prod 共用（v198，見 src/storage/sharedIssuesDb.js＋scripts/migrate-shared-issues.mjs）：
# 指向共用 sqlite 檔絕對路徑，dev/prod 兩個 Node 實例的 .env 必須設為完全相同的值，才能共用同一份
# 問題回報／許願池清單（任一邊回報、回覆、驗證結案都會同步呈現）。首次啟用前須先跑一次
# scripts/migrate-shared-issues.mjs 把兩邊既有的 issues.json 合併進這個檔案（腳本可重跑、
# idempotent，見腳本檔頭用法）。建議路徑：放在雙方都能存取、但不屬於任一邊部署目錄的共用位置，
# 例如 /home/scc-s-admin/scc-shared/issues.sqlite（不可放進 ~/scc-dev 或 ~/scc-prod 目錄底下，
# 避免與該環境自己的 git pull／備份流程混淆）。留空（預設）＝完全不啟用，issues.json 照舊落在
# 各自環境自己的主庫（現行行為不變）。
SHARED_ISSUES_DB=

# v200：附件跨環境唯讀 fallback（src/actions/attachments.js downloadFileBase64 Tier 2）——指向
# 「對方環境」（dev 這裡填 prod 的、prod 這裡填 dev 的）主庫 DB_PATH 絕對路徑，本端以唯讀連線開啟。
# 只有 fileId 先通過 SHARED_ISSUES_DB issues.json 的附件白名單比對，才會被拿來查找——本庫查無
# 不代表可以任意翻對方整個資料庫。留空（預設）＝此 fallback 不啟用，行為與改動前一致。
PEER_DB=

# v200：附件 Drive 舊資料唯讀 fallback（src/actions/attachments.js downloadFileBase64 Tier 3）——
# cutover 前（GAS+Drive 時代）上傳的附件，fileId 是真實 Google Drive file id。逗號分隔的允許
# 系統根資料夾 id 清單，建議同時列入 dev／prod 兩個環境的 ROOT_FOLDER_ID（例如
# 1rZuVUhpHwrSYc2E0yJRvf7NaqS1lGcdx,<prod 的 ROOT_FOLDER_ID>），讓任一環境都能唯讀開啟兩邊
# cutover 前的舊附件；只有 fileId 沿 Drive parents 鏈上溯確實能到達清單中的某個根才會放行。
# 搭配上方 DRIVE_SYNC_CREDS 使用，兩者皆須設定才會啟用；任一留空（預設）＝此 fallback 不啟用。
DRIVE_LEGACY_ROOTS=

# 日曆同步（scripts/gc-sync-tick.js＋dispatch 7 個日曆 action：createCalendarEvent／
# updateCalendarEvent／deleteCalendarEvent／listCalendarEvents／shareCalendarWriters／
# gcAnnotateEvent／getCalendarMeta，＋bookingsCommit 的 gc 參數）專用：OAuth 憑證 JSON 檔路徑
# （{client_id, client_secret, refresh_token}，refresh_token 的 scope 需含
# https://www.googleapis.com/auth/calendar）。留空則：7 個日曆 action 回業務錯誤；
# bookingsCommit 靜默維持 Phase 1.5 行為（只做 RMW，不觸網，gcErrors 恆為空陣列）。
CALENDAR_SYNC_CREDS=

# 日曆名稱：對映 GAS 版 dev='[DEV] SCC 空間預約'／prod='SCC 空間預約'（依部署環境分別在各自
# .env 設定，不可帶錯——帶到另一環境的日曆名稱會導致同步寫入別的行事曆）。
GC_CALENDAR_NAME=[DEV] SCC 空間預約

# 寄信（登入通知信／打卡彙整信，見 src/mail/mailer.js）專用：OAuth 憑證 JSON 檔路徑
# （{client_id, client_secret, refresh_token}，refresh_token 的 scope 需含
# https://www.googleapis.com/auth/gmail.send）。可與上方 CALENDAR_SYNC_CREDS 指向同一檔——
# npust.scc 帳號的憑證可同時含 calendar 與 gmail.send 兩種 scope，不需為每種用途各辦一份憑證。
# 留空則寄信一律降級為 audit-only（記稽核、mailSent:false，不寄信、不阻斷登入/打卡等主流程）。
MAIL_SEND_CREDS=

# 打卡權杖管理橋接（dispatch clockTokenIssue/clockTokenRevoke/clockTokenList → GAS）：
# 打卡系統永久留在 GAS＋Drive，簽發/停用打卡網址由 Node 以共享密鑰轉發 GAS 執行。
# GAS_BRIDGE_URL＝對應環境 GAS 部署的 /exec 網址（dev 對 dev、prod 對 prod，不可交叉）；
# GAS_BRIDGE_KEY＝GAS 編輯器執行 setupBridgeKey() 產生的密鑰（Script Properties BRIDGE_KEY）。
# 留空則這三個 action 回業務錯誤，其餘功能不受影響。
GAS_BRIDGE_URL=
GAS_BRIDGE_KEY=

# 信任裝置憑證效期（天，Phase 3b）：已註冊 TOTP 的帳號，帶有效裝置憑證登入時可免輸入 TOTP
# （httpOnly cookie，伺服器端可逐台撤銷，見 auth/deviceTrust.js）。留空則預設 30。
TRUSTED_DEVICE_DAYS=30

# v202：校內 openmail 收發信（Openfind Mail2000 V8.00，見 src/openmail/）連線設定。使用者自行
# 輸入自己的 openmail 帳密（omConnect），密碼只存記憶體、與登入 session 同壽命、永不落地（見
# src/openmail/credStore.js）；此處只設定伺服器要連去哪個主機/port，皆選填，留空採實測可用的
# 預設值（mail.npust.edu.tw，IMAPS 993／SMTPS 465）。
OPENMAIL_IMAP_HOST=mail.npust.edu.tw
OPENMAIL_IMAP_PORT=993
OPENMAIL_SMTP_HOST=mail.npust.edu.tw
OPENMAIL_SMTP_PORT=465

NODE_ENV=development
